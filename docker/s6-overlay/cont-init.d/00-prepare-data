#!/command/with-contenv sh
# Skapa data-undermappar och kopiera default-config om de saknas.
set -eu

echo "[init] Förbereder /data"
mkdir -p /data/grafana /data/grafana/logs /data/grafana/plugins /data/grafana/dashboards /data/vm

# Lägg in hosts-aliaser så samma Grafana-provisioning fungerar både i
# dev-compose (där tjänsterna är separata containers med Docker-DNS) och
# i single-image (där alla processer är samma container).
if ! grep -q "coordinator victoriametrics" /etc/hosts 2>/dev/null; then
    echo "127.0.0.1 coordinator victoriametrics" >> /etc/hosts || true
    echo "[init] Lade till hosts-aliaser coordinator/victoriametrics -> 127.0.0.1"
fi

if [ ! -f /data/config.yaml ]; then
    echo "[init] Kopierar default config -> /data/config.yaml"
    cp /usr/share/nkn-mon/config.yaml.default /data/config.yaml
fi

if [ -z "$(ls -A /data/grafana/dashboards 2>/dev/null)" ]; then
    echo "[init] Kopierar default-dashboards -> /data/grafana/dashboards"
    cp -r /usr/share/grafana/dashboards-default/. /data/grafana/dashboards/
fi

# Bundlade plugins (yesoreyeram-infinity-datasource) installeras i build-tid
# i plugins-bundled. Grafana läser dock från /data/grafana/plugins (volymen)
# pga GF_PATHS_PLUGINS. Kopiera dem dit vid första start om de saknas.
if [ -d /usr/share/grafana/plugins-bundled ]; then
    for plugin_dir in /usr/share/grafana/plugins-bundled/*/; do
        [ -d "$plugin_dir" ] || continue
        plugin_name=$(basename "$plugin_dir")
        if [ ! -d "/data/grafana/plugins/$plugin_name" ]; then
            echo "[init] Kopierar plugin $plugin_name -> /data/grafana/plugins/"
            cp -r "$plugin_dir" "/data/grafana/plugins/$plugin_name"
        fi
    done
fi

# Provisioneringen pekar på /var/lib/grafana/dashboards (samma som dev-compose).
# I single-image vill vi dock persistera under /data, så symlinka hit.
mkdir -p /var/lib/grafana
rm -rf /var/lib/grafana/dashboards
ln -sfn /data/grafana/dashboards /var/lib/grafana/dashboards
