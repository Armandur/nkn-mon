# Värden här används av docker-compose.prod.yml. I dev finns rimliga defaults i compose.

# Coordinator
COORDINATOR_SECRET=change-me
ADMIN_USER=admin
ADMIN_TOKEN=change-me-admin-token

# PostgreSQL (används från Iteration 2 och framåt)
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://nkn:change-me@postgres:5432/nkn

# Grafana
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_PUBLIC_URL=https://nkn-monitor.example.org
